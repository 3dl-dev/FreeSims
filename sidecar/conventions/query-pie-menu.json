{
  "convention": "freesims",
  "version": "1.0",
  "operation": "query-pie-menu",
  "description": "Query available interactions (pie menu) for a Sim on a target object",
  "args": [
    {"name": "sim_id", "type": "integer", "required": true, "description": "PersistID of the Sim"},
    {"name": "target_object_id", "type": "integer", "required": true, "description": "ObjectID of the target object"}
  ],
  "produces_tags": [{"tag": "freesims:query-pie-menu", "cardinality": "exactly_one"}],
  "antecedents": "none",
  "signing": "member_key",
  "rate_limit": {"max": 30, "per": "sender", "window": "1m"},
  "response": "sync"
}
