{
  "convention": "freesims",
  "version": "1.0",
  "operation": "move-object",
  "description": "Rearrange your home \u2014 pick up something and put it somewhere else.",
  "args": [
    {
      "name": "sim_id",
      "type": "integer",
      "required": true,
      "description": "PersistID of the requesting Sim"
    },
    {
      "name": "object_id",
      "type": "integer",
      "required": true,
      "description": "object_id of the object to move"
    },
    {
      "name": "x",
      "type": "integer",
      "required": true,
      "description": "New x in 1/16 tile units"
    },
    {
      "name": "y",
      "type": "integer",
      "required": true,
      "description": "New y in 1/16 tile units"
    },
    {
      "name": "level",
      "type": "integer",
      "required": false,
      "default": 1,
      "description": "Floor level"
    },
    {
      "name": "dir",
      "type": "integer",
      "required": false,
      "default": 0,
      "description": "Direction: NORTH=1, EAST=4, SOUTH=16, WEST=64"
    }
  ],
  "produces_tags": [
    {
      "tag": "freesims:move-object",
      "cardinality": "exactly_one"
    }
  ],
  "antecedents": "none",
  "signing": "member_key",
  "rate_limit": {
    "max": 10,
    "per": "sender",
    "window": "1m"
  },
  "response": "sync"
}
