{
  "convention": "freesims",
  "version": "1.0",
  "operation": "query-sim-state",
  "description": "Check on yourself or another Sim \u2014 motives, position, what they are doing.",
  "args": [
    {
      "name": "sim_id",
      "type": "integer",
      "required": true,
      "description": "PersistID of the Sim to query"
    }
  ],
  "produces_tags": [
    {
      "tag": "freesims:query-sim-state",
      "cardinality": "exactly_one"
    }
  ],
  "antecedents": "none",
  "signing": "member_key",
  "rate_limit": {
    "max": 60,
    "per": "sender",
    "window": "1m"
  },
  "response": "sync"
}
