{
  "convention": "freesims",
  "version": "1.0",
  "operation": "remember",
  "description": "Hold onto a thought. Your memories carry forward and help you make sense of what happens next.",
  "args": [
    {
      "name": "sim_id",
      "type": "integer",
      "required": true,
      "description": "PersistID of the remembering Sim"
    },
    {
      "name": "fact",
      "type": "string",
      "required": true,
      "maxLength": 500,
      "description": "The fact to remember (\u2264500 chars)"
    }
  ],
  "produces_tags": [
    {
      "tag": "freesims:remember",
      "cardinality": "exactly_one"
    }
  ],
  "antecedents": "none",
  "signing": "member_key",
  "rate_limit": {
    "max": 20,
    "per": "sender",
    "window": "1m"
  },
  "response": "sync"
}
