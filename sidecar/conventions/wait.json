{
  "convention": "freesims",
  "version": "1.0",
  "operation": "wait",
  "description": "Just be. Not every moment needs action. Sometimes you sit with your thoughts.",
  "args": [
    {
      "name": "ticks",
      "type": "integer",
      "required": false,
      "min": 1,
      "max": 120,
      "description": "How many ticks to wait (default 30, max 120)"
    }
  ],
  "produces_tags": [
    {
      "tag": "freesims:wait",
      "cardinality": "exactly_one"
    }
  ],
  "antecedents": "none",
  "signing": "member_key",
  "rate_limit": {
    "max": 60,
    "per": "sender",
    "window": "1m"
  },
  "response": "sync"
}
