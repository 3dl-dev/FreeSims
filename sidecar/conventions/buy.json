{
  "convention": "freesims",
  "version": "1.0",
  "operation": "buy",
  "description": "Purchase an object from the catalog and place it on the lot. Costs simoleons from your funds. Use query-catalog first to see what's available and get GUIDs.",
  "args": [
    {"name": "sim_id", "type": "integer", "required": true, "description": "PersistID of the buying Sim"},
    {"name": "guid", "type": "integer", "required": true, "description": "Catalog GUID of the object to buy (from query-catalog results)"},
    {"name": "x", "type": "integer", "required": true, "description": "Placement x in 1/16 tile units"},
    {"name": "y", "type": "integer", "required": true, "description": "Placement y in 1/16 tile units"},
    {"name": "level", "type": "integer", "required": false, "default": 1, "description": "Floor level"},
    {"name": "dir", "type": "integer", "required": false, "default": 0, "description": "Direction: NORTH=1, EAST=4, SOUTH=16, WEST=64"}
  ],
  "produces_tags": [{"tag": "freesims:buy", "cardinality": "exactly_one"}],
  "antecedents": "none",
  "signing": "member_key",
  "rate_limit": {"max": 10, "per": "sender", "window": "1m"},
  "response": "sync"
}
